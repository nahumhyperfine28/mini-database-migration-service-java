# Source MySQL settings
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_DATABASE=source_db
MYSQL_SCHEMA=source_db
MYSQL_USERNAME=migration_user
MYSQL_PASSWORD=migration_password
